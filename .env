# App identity (must match electron-builder appId / productName)
APP_ID=com.localai.desktop
APP_NAME=LocalAI

# Local AI stack
SERVICE_HOST=localhost
WEBUI_PORT=3000
OLLAMA_PORT=11434
CONTAINER_NAME=open-webui
DOCKER_IMAGE=ghcr.io/open-webui/open-webui:main

# Models
DEFAULT_MODEL=llama3.2
DEFAULT_MODELS=llama3.2,gemma2:2b

# Network timeouts (ms)
REQUEST_TIMEOUT_MS=3000

# Dev only — set true to auto-open DevTools in the control window
DEV_OPEN_DEVTOOLS=false
