# App identity (must match electron-builder appId / productName)
VITE_APP_ID=com.localai.desktop
VITE_APP_NAME=LocalAI

# Local AI stack
VITE_SERVICE_HOST=localhost
VITE_WEBUI_PORT=3000
VITE_OLLAMA_PORT=11434
VITE_CONTAINER_NAME=open-webui
VITE_DOCKER_IMAGE=ghcr.io/open-webui/open-webui:main
VITE_SEARXNG_CONTAINER_NAME=searxng
VITE_SEARXNG_IMAGE=docker.io/searxng/searxng:latest
VITE_SEARXNG_PORT=8080

# Models
VITE_DEFAULT_MODEL=llama3.2
VITE_DEFAULT_MODELS=llama3.2,gemma2:2b

# Network timeouts (ms)
VITE_REQUEST_TIMEOUT_MS=3000
